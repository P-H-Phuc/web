<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="web_preview_ms_office.AttachmentViewer" owl="1" t-inherit="mail.AttachmentViewer" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o_AttachmentViewer_icon')]" position="inside">
            <t t-if="attachmentViewer.attachmentViewerViewable.isMsOfficeDocument">
                <i class="fa fa-file-word-o" role="img" title="MS Office File"/>
            </t>
        </t>
        <xpath expr="//div[hasclass('o_AttachmentViewer_main')]" position="inside">
            <t t-if="attachmentViewer.attachmentViewerViewable.isMsOfficeDocument">
                <iframe class="o_AttachmentViewer_view o_AttachmentViewer_viewIframe o_AttachmentViewer_viewMsOffice w-75 h-100 border-0" t-att-src="attachmentViewer.attachmentViewerViewable.defaultSource"/>
            </t>
        </xpath>
    </t>

</templates>
