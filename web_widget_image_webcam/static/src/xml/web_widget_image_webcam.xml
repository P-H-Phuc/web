<template>
    <t
        t-name="web_widget_image_webcam.ImageField"
        t-inherit="web.ImageField"
        t-inherit-mode="extension"
    >
        <xpath expr="//button[hasclass('o_clear_file_button')]" position="before">
            <button
                class="o_form_binary_file_web_cam btn btn-light border-0 rounded-circle m-1 p-1"
                data-tooltip="WebCam"
                aria-label="WebCam"
            >
                <i class="fa fa-eye" t-on-click="onWebcamClicked" />
            </button>
        </xpath>
    </t>

    <t t-name="web_widget_image_webcam.WebCamDialog">
        <Dialog title="props.title">
            <div class="container-fluid">
                <div class="row">
                    <div class="col-md-5 live_webcam_outer_div">
                        <div t-ref="live_webcam" id="live_webcam" />
                    </div>
                    <div class="col-md-2 mt64 direction_icon fa fa-angle-right fa-8x" />
                    <div class="col-md-5 webcam_result_outer_div" id="webcam_result">
                        <img
                            t-if="imageData.src"
                            class="webcam_result_img"
                            t-att-src="imageData.src"
                            alt="Webcam Snapshot"
                        />
                        <img
                            t-else=""
                            src="/web_widget_image_webcam/static/src/img/webcam_placeholder.png"
                        />
                    </div>
                </div>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-primary take_snap_btn" t-on-click="onTakeSnap">
                    Take Snapshot
                </button>
                <button
                    class="btn btn-primary save_close_btn"
                    t-on-click="onSaveClose"
                    t-att-disabled="!isLive"
                >
                    Save &amp; Close
                </button>
                <button
                    class="btn btn-secondary"
                    t-on-click="props.close"
                >Close</button>
            </t>
        </Dialog>
    </t>
</template>
